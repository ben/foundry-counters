{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@common/*": ["./types/foundry/common/*"],
      "@client/*": ["./types/foundry/client/*"]
    }
  },
  "include": [
    "src/**/*",
    "vite.config.ts",
    "types/foundry/global-external.d.mts"
  ]
}
